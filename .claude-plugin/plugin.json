{
  "name": "vnext-ai-toolkit",
  "version": "0.0.2",
  "description": "AI tooling for the vNext platform: process designer (multi-turn architect), component scaffolders (workflow/view/schema/task/function/extension), workspace bootstrap, integration test scaffolding. Canonical schema-first — every component is generated from the official JSON Schema at the workspace's schemaVersion tag, never from hardcoded assumptions.",
  "author": {
    "name": "Burgan Tech vNext Team",
    "url": "https://github.com/burgan-tech"
  },
  "homepage": "https://github.com/burgan-tech/vnext-ai-toolkit",
  "repository": "https://github.com/burgan-tech/vnext-ai-toolkit",
  "license": "MIT",
  "keywords": [
    "vnext",
    "workflow",
    "domain-driven",
    "scaffolding",
    "claude-code",
    "burgan-tech"
  ],
  "compatibleAgents": [
    "claude-code",
    "codex"
  ],
  "agents": [
    "./agents/analyst.md",
    "./agents/architect.md",
    "./agents/component-author.md",
    "./agents/validator.md",
    "./agents/reviewer.md",
    "./agents/security-reviewer.md",
    "./agents/doc-writer.md",
    "./agents/vnext-architect.md"
  ],
  "commands": [
    "./commands/vnext-init.md",
    "./commands/new-component.md",
    "./commands/vnext-design-process.md",
    "./commands/validate.md",
    "./commands/review-components.md",
    "./commands/build.md"
  ],
  "skills": [
    "./skills/authoring-vnext-components",
    "./skills/workflow-scaffold",
    "./skills/view-design",
    "./skills/schema-design",
    "./skills/component-task",
    "./skills/component-function",
    "./skills/component-extension",
    "./skills/component-mapping",
    "./skills/integration-test",
    "./skills/validate-and-fix"
  ],
  "references": [
    "references/decision-tree.md",
    "references/external-sources.md",
    "references/concepts/workflow-types.md",
    "references/concepts/view-roles.md",
    "references/concepts/roles-and-authorization.md",
    "references/concepts/function-vs-extension-vs-task.md",
    "references/concepts/mappings-and-scripts.md",
    "references/concepts/mapping-types.md",
    "references/concepts/csx-contracts.md",
    "references/concepts/schema-vocabularies.md",
    "references/concepts/component-schemas.md",
    "references/concepts/mocklab-spec.md",
    "references/concepts/integration-test-patterns.md"
  ],
  "vnext": {
    "schemaSource": "node_modules/@burgan-tech/vnext-schema/schemas/{componentType}-definition.schema.json",
    "knowledgeOrder": [
      "pinned @burgan-tech/vnext-schema (node_modules)",
      "Context7 MCP (/burgan-tech/vnext-docs, /burgan-tech/vnext-example)",
      "WebFetch https://burgan-tech.github.io/vnext-docs"
    ],
    "componentTypes": [
      "workflow",
      "view",
      "task",
      "schema",
      "function",
      "extension",
      "mapping"
    ]
  }
}
