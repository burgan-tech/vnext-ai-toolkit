using System.Threading.Tasks;
using Xunit;
using {{Domain}}.IntegrationTests.Infrastructure;

namespace {{Domain}}.IntegrationTests;

/// <summary>
/// Minimum-viable proof the runtime stack is healthy. Runs first; if these fail, all other tests will fail too.
/// </summary>
public class SmokeTests : IntegrationTestBase
{
    public SmokeTests(VNextTestEnvironment env) : base(env) { }

    [Fact]
    public async Task Runtime_Is_Healthy()
    {
        var ok = await Api.HealthAsync();
        Assert.True(ok, "Runtime health endpoint did not return 200 — is the Docker stack up? (docker compose up -d)");
    }

    [Fact]
    public async Task Can_List_Instances_Endpoint_Responds()
    {
        // We don't assert on contents — just that the endpoint is reachable and returns a list shape.
        // Replace "example-workflow" with an actual workflow key once one exists in this domain.
        var result = await Api.ListInstancesAsync(workflowKey: "example-workflow");
        Assert.NotNull(result);
    }
}
