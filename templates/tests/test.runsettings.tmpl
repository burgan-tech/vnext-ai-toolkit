<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>./TestResults</ResultsDirectory>
    <TestSessionTimeout>600000</TestSessionTimeout>
    <DisableAppDomain>true</DisableAppDomain>
  </RunConfiguration>

  <!-- xUnit: serialize collections so the Docker stack isn't restarted per test -->
  <xunit>
    <ParallelizeAssembly>false</ParallelizeAssembly>
    <ParallelizeTestCollections>false</ParallelizeTestCollections>
    <MaxParallelThreads>1</MaxParallelThreads>
  </xunit>

  <!-- Test environment knobs read by VNext.Testing.Sdk -->
  <TestRunParameters>
    <Parameter name="vnext:domain"        value="{{domain}}" />
    <Parameter name="vnext:imageTag"      value="latest" />
    <Parameter name="vnext:runtimePort"   value="4201" />
    <Parameter name="vnext:mocklabPort"   value="3001" />
    <Parameter name="vnext:hostNetwork"   value="bbt-development" />
  </TestRunParameters>
</RunSettings>
