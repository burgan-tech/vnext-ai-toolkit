{
  "version": "1.0.0",
  "description": "{{domain}} Domain Definition Configuration",
  "domain": "{{domain}}",
  "runtimeVersion": "{{runtimeVersion}}",
  "schemaVersion": "{{schemaVersion}}",
  "paths": {
    "componentsRoot": "{{domain}}",
    "tasks": "Tasks",
    "views": "Views",
    "functions": "Functions",
    "extensions": "Extensions",
    "workflows": "Workflows",
    "schemas": "Schemas"
  },
  "exports": {
    "functions": [],
    "workflows": [],
    "tasks": [],
    "views": [],
    "schemas": [],
    "extensions": [],
