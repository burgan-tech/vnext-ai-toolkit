    "metadata": {
      "description": "Exported components for {{domain}} domain",
      "maintainer": "{{maintainer}}",
      "license": "MIT",
      "keywords": ["{{domain}}", "vnext", "workflow", "domain"]
    }
  },
  "dependencies": {
    "domains": [],
    "npm": []
  },
  "referenceResolution": {
    "enabled": true,
    "validateOnBuild": true,
    "strictMode": true,
