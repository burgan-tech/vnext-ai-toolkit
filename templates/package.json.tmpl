{
  "name": "@burgan-tech/vnext-{{domain}}",
  "version": "0.0.1",
  "description": "vNext {{domain}} domain — workflows, schemas, views, functions, tasks, extensions",
  "main": "index.js",
  "scripts": {
    "validate": "node validate.js",
    "build": "node build.js",
    "build:reference": "node build.js -t reference",
    "build:runtime": "node build.js -t runtime",
    "sync-schema": "node sync-schema-version.js",
    "setup": "node setup.js",
    "postinstall": "node setup.js && npm run sync-schema",
    "prepublishOnly": "npm run sync-schema && npm run validate"
  },
  "keywords": [
    "vnext",
    "workflow",
    "{{domain}}",
    "domain-driven",
    "burgan-tech"
  ],
  "author": "{{maintainer}}",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@burgan-tech/vnext-schema": "^{{schemaVersion}}",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "dependencies": {
    "@burgan-tech/vnext-schema": "^{{schemaVersion}}"
  }
}
